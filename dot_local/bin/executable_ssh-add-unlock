#!/usr/bin/env bash
# Unlock SSH keys via the desktop session's askpass + secret store.
# Auto-detects the askpass binary so the same script works under KDE
# (ksshaskpass + KWallet), GNOME (seahorse + gnome-keyring), and any
# Wayland compositor (Hyprland, Niri, sway) that has either daemon running.

set -Eeuo pipefail

# No GUI session => nothing to do. Exit clean so the systemd unit doesn't
# fail on TTY-only logins or servers.
if [[ -z "${DISPLAY:-}" && -z "${WAYLAND_DISPLAY:-}" ]]; then
    exit 0
fi

function find_askpass() {
    local candidate
    for candidate in \
        ksshaskpass \
        /usr/libexec/seahorse/ssh-askpass \
        /usr/lib/seahorse/ssh-askpass \
        /usr/libexec/openssh/gnome-ssh-askpass \
        lxqt-openssh-askpass \
        x11-ssh-askpass \
        ssh-askpass; do
        if [[ "${candidate}" == /* ]]; then
            [[ -x "${candidate}" ]] && { printf '%s\n' "${candidate}"; return 0; }
        else
            command -v "${candidate}" >/dev/null 2>&1 && { command -v "${candidate}"; return 0; }
        fi
    done
    return 1
}

if ! askpass="$(find_askpass)"; then
    printf 'ssh-add-unlock: no askpass binary found\n' >&2
    exit 1
fi

export SSH_ASKPASS="${askpass}"
export SSH_ASKPASS_REQUIRE='prefer'

# `ssh-add` with no args loads the default identities. Already-loaded keys
# are silently skipped, so this is safe to run on every session start.
exec ssh-add -q
