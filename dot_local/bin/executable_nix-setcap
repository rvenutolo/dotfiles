#!/usr/bin/env bash

# Apply Linux capabilities to nix-installed network tools so they can run
# unprivileged. Nix store paths change on each profile generation, so this
# is meant to be invoked by a systemd path unit watching the nix profile.
#
# Requires a sudoers entry granting NOPASSWD for /usr/sbin/setcap.

set -Eeuo pipefail
IFS=$'\n\t'
trap 'printf "error: line %s (exit %s): %s\n" "${LINENO}" "$?" "${BASH_COMMAND}" >&2' ERR

# Format: "<binary-name-in-PATH> <caps-string>"
readonly TARGETS=(
  'bandwhich cap_net_raw,cap_net_admin+eip'
  'iftop cap_net_raw+eip'
  'mtr-packet cap_net_raw+eip'
  'nmap cap_net_raw,cap_net_admin,cap_net_bind_service+eip'
  'tcpdump cap_net_raw,cap_net_admin+eip'
  'traceroute cap_net_raw+eip'
)
readonly PROFILE_BIN="${HOME}/.nix-profile/bin"
readonly SETCAP='/usr/sbin/setcap'
readonly GETCAP='/usr/sbin/getcap'

function log() {
  printf '[%s] %-5s %s\n' "$(date '+%Y-%m-%dT%H:%M:%S%z')" "$1" "$2" >&2
}
function log_info() { log INFO "$*"; }
function log_warn() { log WARN "$*"; }
function log_err() { log ERROR "$*"; }

# @description Apply one capability entry to its nix-profile target binary.
#   Skips entries whose binary is not installed in the nix profile or whose
#   store target has gone missing. Skips a no-op setcap when the desired caps
#   are already present, so the script is idempotent across path-unit fires.
# @arg $1 name binary basename inside ${HOME}/.nix-profile/bin
# @arg $2 caps capabilities string in setcap(8) syntax
function apply_caps() {
  local -r name="$1"
  local -r caps="$2"
  local -r link="${PROFILE_BIN}/${name}"

  if [[ ! -e "${link}" ]]; then
    log_info "skip ${name} (not installed)"
    return 0
  fi

  local target
  target="$(readlink --canonicalize "${link}")"
  if [[ ! -f "${target}" ]]; then
    log_warn "skip ${name} (target ${target} missing)"
    return 0
  fi

  local current
  current="$("${GETCAP}" "${target}" 2> /dev/null | sed --regexp-extended 's|.* = ||' || true)"
  if [[ "${current}" == "${caps}" ]]; then
    log_info "${name} already has ${caps}"
    return 0
  fi

  log_info "applying ${caps} to ${name} -> ${target}"
  sudo "${SETCAP}" "${caps}" "${target}"
}

# @description Iterate TARGETS and apply each capability entry.
# @noargs
function main() {
  if [[ ! -x "${SETCAP}" || ! -x "${GETCAP}" ]]; then
    log_err "missing ${SETCAP} or ${GETCAP}"
    exit 1
  fi

  local entry name caps
  for entry in "${TARGETS[@]}"; do
    name="${entry%% *}"
    caps="${entry#* }"
    apply_caps "${name}" "${caps}"
  done
}

main "$@"
