#!/usr/bin/env bash
# /etc/NetworkManager/dispatcher.d/99-vpn-dns-fix
#
# When the AWS VPN tun0 interface comes up, add ~amazonaws.com as a routing
# domain so CNAME chases from *.deint.net to *.amazonaws.com stay on the VPN
# resolver (10.131.0.2) instead of falling through to the default-route
# resolver, which on some networks (AT&T residential gateways) strips A records
# pointing into RFC 1918 space.

set -Eeuo pipefail
IFS=$'\n\t'
trap 'echo "error: line ${LINENO} (exit $?): ${BASH_COMMAND}" >&2' ERR

readonly WANT='~amazonaws.com'
# A domain the AWS client always pushes; used as the race-guard sentinel.
readonly SENTINEL='digitalenvoy.net'
# Up to ~5s of polling at 0.1s intervals.
readonly MAX_ATTEMPTS=50

# @description Header-free read of tun0's current routing domains.
#   'resolvectl domain tun0' hard-wraps long domain lists across multiple
#   physical lines (at ~72 columns, even when piped), so a per-line parse would
#   silently drop every domain past the wrap. Fold the output back into a single
#   line first, then strip the "Link N (tun0): " header. This can never leak the
#   header in as a bogus domain, and an empty list yields zero domains.
# @noargs
# @stdout One routing domain per line.
function read_domains() {
  resolvectl domain tun0 \
    | tr '\n' ' ' \
    | sed --regexp-extended 's/^Link [0-9]+ \([^)]*\): //' \
    | tr ' ' '\n' \
    | grep --invert-match '^$' || true
}

# @description NetworkManager dispatcher entry point.
# @arg $1 interface name NetworkManager brings up/down
# @arg $2 action the dispatcher event (e.g. up, vpn-up)
function main() {
  local -r interface="$1"
  local -r action="$2"

  if [[ "${interface}" != 'tun0' ]]; then
    exit 0
  fi

  case "${action}" in
    up | vpn-up)
      ;;
    *)
      exit 0
      ;;
  esac

  if ! command -v resolvectl > /dev/null 2>&1; then
    echo 'resolvectl not found' >&2
    exit 1
  fi

  # Race guard: the AWS --up script sets tun0 domains asynchronously. Wait until
  # the sentinel appears before we touch the list, so a read-modify-write can
  # never lose the AWS-pushed domains.
  local -a domains=()
  local attempt=1
  local domain
  while ((attempt <= MAX_ATTEMPTS)); do
    mapfile -t domains < <(read_domains)
    for domain in "${domains[@]}"; do
      if [[ "${domain}" == "${SENTINEL}" ]]; then
        break 2
      fi
    done
    sleep 0.1
    attempt=$((attempt + 1))
  done

  # Idempotent: already applied.
  for domain in "${domains[@]}"; do
    if [[ "${domain}" == "${WANT}" ]]; then
      exit 0
    fi
  done

  # Fail-safe: never write if we didn't see real domains — better to leave the
  # AWS-pushed list intact than to clobber it.
  if [[ "${#domains[@]}" -eq 0 ]]; then
    exit 0
  fi

  resolvectl domain tun0 "${domains[@]}" "${WANT}"
  resolvectl flush-caches
}

main "$@"
