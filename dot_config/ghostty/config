# Font
font-family = JetBrainsMono Nerd Font
font-size = 11

# Theme
theme = Nord
background-opacity = 1.0
bold-color = bright
unfocused-split-opacity = 0.7
window-colorspace = srgb

# Cursor
cursor-style = block
cursor-style-blink = true

# Window
window-width = 120
window-height = 36
window-padding-x = 6
window-padding-y = 6
window-padding-balance = true
window-save-state = never
confirm-close-surface = false
working-directory = home
window-inherit-working-directory = false
tab-inherit-working-directory = true
split-inherit-working-directory = true

# Tabs (Linux/GTK)
gtk-tabs-location = top
gtk-titlebar = true
gtk-single-instance = true

# Scrollback (bytes; ~10000 lines at avg 100 bytes/line)
scrollback-limit = 1000000

# Mouse / selection
mouse-hide-while-typing = true
link-url = true
copy-on-select = clipboard
clipboard-trim-trailing-spaces = true

# Shell integration
shell-integration = detect
shell-integration-features = cursor,sudo,title

# Updates / notifications
auto-update = off
app-notifications = no-clipboard-copy

# Linux
linux-cgroup = single-instance
quit-after-last-window-closed = true

# Keybindings - windows / tabs
keybind = ctrl+shift+n=new_window
keybind = ctrl+shift+t=new_tab
keybind = ctrl+shift+w=close_surface
keybind = ctrl+tab=next_tab
keybind = ctrl+shift+tab=previous_tab
keybind = ctrl+shift+one=goto_tab:1
keybind = ctrl+shift+two=goto_tab:2
keybind = ctrl+shift+three=goto_tab:3
keybind = ctrl+shift+four=goto_tab:4
keybind = ctrl+shift+five=goto_tab:5
keybind = ctrl+shift+six=goto_tab:6
keybind = ctrl+shift+seven=goto_tab:7
keybind = ctrl+shift+eight=goto_tab:8
keybind = ctrl+shift+nine=goto_tab:9

# Keybindings - splits
keybind = ctrl+shift+enter=new_split:right
keybind = ctrl+shift+d=new_split:down
keybind = ctrl+shift+left=goto_split:left
keybind = ctrl+shift+right=goto_split:right
keybind = ctrl+shift+up=goto_split:up
keybind = ctrl+shift+down=goto_split:down
keybind = ctrl+alt+left=resize_split:left,20
keybind = ctrl+alt+right=resize_split:right,20
keybind = ctrl+alt+up=resize_split:up,20
keybind = ctrl+alt+down=resize_split:down,20
keybind = ctrl+shift+z=toggle_split_zoom

# Keybindings - font sizing
keybind = ctrl+shift+equal=increase_font_size:2
keybind = ctrl+shift+plus=increase_font_size:2
keybind = ctrl+shift+minus=decrease_font_size:2
keybind = ctrl+shift+zero=reset_font_size

# Keybindings - clipboard
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard

# Bell
bell-features = audio,attention,title
