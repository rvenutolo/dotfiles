# Font
font-family = JetBrainsMono Nerd Font
font-size = 11

# Theme
theme = Nord
background-opacity = 1.0

# Cursor
cursor-style = block
cursor-style-blink = true

# Window
window-width = 120
window-height = 36
window-padding-x = 6
window-padding-y = 6
window-padding-balance = true
window-save-state = never
confirm-close-surface = false

# Tabs (Linux/GTK)
gtk-tabs-location = top
gtk-titlebar = true
gtk-single-instance = true

# Scrollback
scrollback-limit = 10000000

# Mouse / selection
mouse-hide-while-typing = true
copy-on-select = false
clipboard-trim-trailing-spaces = true

# Shell integration
shell-integration = detect
shell-integration-features = cursor,sudo,title

# Keybindings
keybind = ctrl+shift+n=new_window
keybind = ctrl+shift+t=new_tab
keybind = ctrl+shift+w=close_surface
keybind = ctrl+shift+equal=increase_font_size:2
keybind = ctrl+shift+plus=increase_font_size:2
keybind = ctrl+shift+minus=decrease_font_size:2
keybind = ctrl+shift+0=reset_font_size
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard

# Bell
bell-features = audio,attention,title
