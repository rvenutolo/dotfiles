#!/usr/bin/env sh

# Guard so this file is sourced exactly once per shell process. The guard
# variable is intentionally NOT exported, so child processes start fresh.
if [ -n "${_PROFILE_SH_SOURCED:-}" ]; then
  return
fi
_PROFILE_SH_SOURCED=1

umask 022

# NOTE: This file is rendered from `.chezmoidata.yaml` by chezmoi. Edit
# `.chezmoidata.yaml` to change hostnames/paths/age values, not this file.

# xdg base dirs - https://wiki.archlinux.org/title/XDG_Base_Directory
export XDG_PROJECTS_DIR="${HOME}/{{ .paths.xdg_projects_dir }}"
export XDG_CACHE_HOME="${HOME}/{{ .paths.xdg_cache_home }}"
export XDG_CONFIG_HOME="${HOME}/{{ .paths.xdg_config_home }}"
export XDG_DATA_HOME="${HOME}/{{ .paths.xdg_data_home }}"
export XDG_STATE_HOME="${HOME}/{{ .paths.xdg_state_home }}"
export XDG_DATA_DIRS="${XDG_DATA_DIRS:-}"
export XDG_DATA_DIRS="/var/lib/flatpak/exports/share:${XDG_DATA_DIRS}"
export XDG_DATA_DIRS="${XDG_DATA_HOME}/flatpak/exports/share:${XDG_DATA_DIRS}"
export XDG_DATA_DIRS="${HOME}/.nix-profile/share:${XDG_DATA_DIRS}"
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id --user)}"

# PATH manipulation helpers (sourced once XDG_CONFIG_HOME is set; unset
# at the bottom of this file).
if [ -r "${XDG_CONFIG_HOME}/path-helpers.sh" ]; then
  . "${XDG_CONFIG_HOME}/path-helpers.sh"
fi

# personal env vars
export XDG_BIN_HOME="${HOME}/{{ .paths.xdg_bin_home }}"
export PERSONAL_DESKTOP_HOSTNAME='{{ .hostnames.personal_desktop }}'
export PERSONAL_LAPTOP_HOSTNAME='{{ .hostnames.personal_laptop }}'
export WORK_LAPTOP_HOSTNAME='{{ .hostnames.work_laptop }}'
export PERSONAL_PROJECTS_DIR="${HOME}/{{ .paths.personal_projects_dir }}"
export WORK_PROJECTS_DIR="${HOME}/{{ .paths.work_projects_dir }}"
export SCRIPTS_DIR="${HOME}/{{ .paths.scripts_dir }}"
export DOTFILES_DIR="${HOME}/{{ .paths.dotfiles_dir }}"
export PACKAGES_DIR="${HOME}/{{ .paths.packages_dir }}"
export NIX_USER_PROFILE="${HOME}/{{ .paths.nix_user_profile }}"
export HOME_MANAGER_DIR="${HOME}/{{ .paths.home_manager_dir }}"
export HOME_MANAGER_PACKAGES_DIR="${HOME}/{{ .paths.home_manager_packages_dir }}"
export KEYS_DIR="${HOME}/{{ .paths.keys_dir }}"
export PERSONAL_SSH_PUBLIC_KEY="${HOME}/{{ .paths.personal_ssh_public_key }}"
export PERSONAL_SSH_PRIVATE_KEY="${HOME}/{{ .paths.personal_ssh_private_key }}"
export WORK_SSH_PUBLIC_KEY="${HOME}/{{ .paths.work_ssh_public_key }}"
export WORK_SSH_PRIVATE_KEY="${HOME}/{{ .paths.work_ssh_private_key }}"
export WTTR_CITY='{{ .weather.wttr_city }}'

# age / crypt
export AGE_PUBLIC_KEY='{{ .age.public_key }}'
export AGE_PRIVATE_KEY_FILE="${HOME}/{{ .paths.age_private_key_file }}"
export CRYPT_DIR="${HOME}/{{ .paths.crypt_dir }}"

## dirs and files
export ANDROID_HOME="${XDG_DATA_HOME}/android"
export ATOM_HOME="${XDG_DATA_HOME}/atom"
export AWS_CONFIG_FILE="${XDG_CONFIG_HOME}/aws/config"
export AWS_SHARED_CREDENTIALS_FILE="${XDG_CONFIG_HOME}/aws/credentials"
export CARGO_HOME="${XDG_DATA_HOME}/cargo"
export CLAUDE_CONFIG_DIR="${XDG_CONFIG_HOME}/claude/personal"
export DOCKER_CONFIG="${XDG_CONFIG_HOME}/docker"
export FFMPEG_DATADIR="${XDG_CONFIG_HOME}/ffmpeg"
export GEM_HOME="${XDG_DATA_HOME}/gem"
export GEM_SPEC_CACHE="${XDG_CACHE_HOME}/gem"
export GNUPGHOME="${XDG_DATA_HOME}/gnupg"
export GOBIN="${HOME}/.go/bin"
export GOCACHE="${XDG_CACHE_HOME}/go-build"
export GOMODCACHE="${XDG_CACHE_HOME}/go/mod"
export GOPATH="${HOME}/.go"
export GRADLE_USER_HOME="${XDG_DATA_HOME}/gradle"
export GTK2_RC_FILES="${XDG_CONFIG_HOME}/gtk-2.0/gtkrc"
export INPUTRC="${XDG_CONFIG_HOME}/readline/inputrc"
export KDEHOME="${XDG_CONFIG_HOME}/kde"
export LESSHISTFILE="${XDG_STATE_HOME}/less/history"
export NPM_CONFIG_USERCONFIG="${XDG_CONFIG_HOME}/npm/npmrc"
export PARALLEL_HOME="${XDG_CONFIG_HOME}/parallel"
export RIPGREP_CONFIG_PATH="${XDG_CONFIG_HOME}/ripgrep/config"
export RUSTUP_HOME="${XDG_DATA_HOME}/rustup"
export SCREENRC="${XDG_CONFIG_HOME}/screen/screenrc"
export SDKMAN_DIR="${XDG_DATA_HOME}/sdkman"
export SONARLINT_USER_HOME="${XDG_DATA_HOME}/sonarlint"
export STACK_ROOT="${XDG_DATA_HOME}/stack"
export STARSHIP_CACHE="${XDG_CACHE_HOME}/starship"
export TERMINFO="${XDG_DATA_HOME}/terminfo"
export TERMINFO_DIRS="${XDG_DATA_HOME}/terminfo:/usr/share/terminfo"
export WGETRC="${XDG_CONFIG_HOME}/wgetrc"

## misc
export DIFFPROG='meld'
export HSTR_CONFIG='hicolor'
export MAVEN_OPTS='-Xms256m -Xmx1g'
export NIXPKGS_ALLOW_UNFREE='1'
export SSH_AUTH_SOCK="${XDG_RUNTIME_DIR}/ssh-agent.socket"
export SBT_OPTS="-Dsbt.global.base=${XDG_DATA_HOME}/sbt/1.0 -Dsbt.boot.directory=${XDG_CACHE_HOME}/sbt/boot -Dsbt.repository.config=${XDG_CACHE_HOME}/sbt/repositories -Dsbt.ivy.home=${XDG_CACHE_HOME}/ivy2"
export STACK_XDG='1'
export SYSTEMD_PAGER=''

## GPG TTY
# `tty` returns "not a tty" in non-interactive shells, which would set a
# bogus GPG_TTY. Guard so we only export it in interactive shells.
case $- in
  *i*) export GPG_TTY="$(tty)" ;;
esac

## SSH_ASKPASS discovery.
# seahorse + gnome-ssh-askpass ship under libexec (FHS helper convention),
# which is not on PATH, so they're listed by absolute path.
for __askpass in \
  'ksshaskpass' \
  '/usr/libexec/seahorse/ssh-askpass' \
  '/usr/lib/seahorse/ssh-askpass' \
  '/usr/libexec/openssh/gnome-ssh-askpass' \
  'lxqt-openssh-askpass' \
  'x11-ssh-askpass'; do
  case "${__askpass}" in
    /*)
      if [ -x "${__askpass}" ]; then
        export SSH_ASKPASS="${__askpass}"
        break
      fi
      ;;
    *)
      if command -v "${__askpass}" > /dev/null 2>&1; then
        SSH_ASKPASS="$(command -v "${__askpass}")"
        export SSH_ASKPASS
        break
      fi
      ;;
  esac
done
unset __askpass
if [ -n "${SSH_ASKPASS:-}" ]; then
  export SSH_ASKPASS_REQUIRE='prefer'
fi

## editor/visual
if command -v 'micro' > /dev/null 2>&1; then
  export EDITOR='micro'
elif command -v 'nano' > /dev/null 2>&1; then
  export EDITOR='nano'
elif command -v 'nvim' > /dev/null 2>&1; then
  export EDITOR='nvim'
else
  export EDITOR='vim'
fi
if command -v 'lite-xl' > /dev/null 2>&1; then
  export VISUAL='lite-xl'
elif command -v 'kate' > /dev/null 2>&1; then
  export VISUAL='kate'
else
  export VISUAL="${EDITOR}"
fi

# pager
if command -v 'moor' > /dev/null 2>&1; then
  export PAGER='moor'
else
  export PAGER='less --ignore-case'
fi
export MANPAGER="${PAGER}"
export GROFF_NO_SGR=1

# file manager
case "${XDG_CURRENT_DESKTOP:-}" in
  KDE) export FILE_MANAGER='dolphin' ;;
  *GNOME) export FILE_MANAGER='nautilus' ;;
  *) export FILE_MANAGER='ranger' ;;
esac

## less
LESS_TERMCAP_mb=$(tput -T ansi blink) # Begin blinking text
export LESS_TERMCAP_mb
LESS_TERMCAP_md=$(tput -T ansi setaf 2 ; tput -T ansi bold) # Begin bold text
export LESS_TERMCAP_md
LESS_TERMCAP_me=$(tput -T ansi sgr0)  # End all formatting modes
export LESS_TERMCAP_me
LESS_TERMCAP_se=$(tput -T ansi rmso)  # End standout mode
export LESS_TERMCAP_se
LESS_TERMCAP_so=$(tput -T ansi smso)  # Begin standout mode (used for highlighting/info boxes)
export LESS_TERMCAP_so
LESS_TERMCAP_ue=$(tput -T ansi rmul)  # End underline
export LESS_TERMCAP_ue
LESS_TERMCAP_us=$(tput -T ansi smul)  # Begin underline
export LESS_TERMCAP_us

## this addresses when ssh-ing to a box that doesn't have terminfo for whatever TERM currently is
for TERM in "${TERM}" 'xterm-256color' 'xterm-16color' 'xterm-color' 'xterm'; do
  if infocmp -0 > /dev/null 2>&1; then
    break
  fi
done

for dir in \
  "${HOME}/.bin" \
  "${HOME}/.local/bin" \
  "${HOME}/.local/share/JetBrains/Toolbox/scripts" \
  "${HOME}/.nix-profile/bin" \
  '/usr/local/sbin' \
  '/usr/local/bin' \
  '/usr/sbin' \
  '/usr/bin' \
  '/sbin' \
  '/bin'; do
  path_append "${dir}"
done
unset -v dir

# nix profile.d files (POSIX sh; set PATH and other env)
for file in \
  "${NIX_USER_PROFILE}/etc/profile.d/nix.sh" \
  "${NIX_USER_PROFILE}/etc/profile.d/hm-session-vars.sh"; do
  if [ -r "${file}" ]; then
    . "${file}"
  fi
done
unset -v file

# scripts dir PATH prepends (put user scripts at front of PATH)
for dir in \
  "${SCRIPTS_DIR}/other" \
  "${SCRIPTS_DIR}/main"; do
  path_prepend "${dir}"
done
unset -v dir

## tailscale
if command -v 'tailscale' > /dev/null 2>&1 && tailscale status > '/dev/null'; then
  export TAILNET_IP="$(tailscale ip -4)"
  export TAILNET_CIDR='100.64.0.0/10'
fi

for file in \
  "${HOME}/.profile-local" \
  "${HOME}/.profile-private"; do
  if [ -r "${file}" ]; then
    . "${file}"
  fi
done
unset -v file

unset -f path_append path_prepend path_remove
