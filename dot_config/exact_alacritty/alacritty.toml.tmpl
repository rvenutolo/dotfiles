import = ["{{ .chezmoi.homeDir }}/{{ .paths.xdg_config_home }}/alacritty/colors.toml", "{{ .chezmoi.homeDir }}/{{ .paths.xdg_config_home }}/alacritty/font.toml"]

[colors]
draw_bold_text_with_bright_colors = true

[cursor.style]
blinking = "On"

[keyboard]
bindings = [
{ key = "N", mods = "Control|Shift", action = "CreateNewWindow" }
]

[scrolling]
history = 10000
multiplier = 10

[selection]
save_to_clipboard = true

[window.dimensions]
columns = 120
lines = 36

[window.padding]
x = 6
y = 6
